# ── State and logs ───────────────────────────────────────────
# These are generated at runtime and should never be committed
state
*.log
*.error.log

# ── macOS system files ────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Generated launchd plist ───────────────────────────────────
